generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  member
}

enum WalletType {
  operational
  wife
  home_setup
  emergency
  custom
}

enum TransactionType {
  expense
  transfer
  top_up
  adjustment
}

enum AdjustmentDirection {
  increase
  decrease
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String   @map("display_name")
  role         UserRole
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  sessions     Session[]
  createdTransactions Transaction[] @relation("CreatedTransactions")
  updatedTransactions Transaction[] @relation("UpdatedTransactions")
  deletedTransactions Transaction[] @relation("DeletedTransactions")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Wallet {
  id             String   @id @default(cuid())
  name           String   @unique
  type           WalletType
  initialBalance Decimal  @default(0) @map("initial_balance") @db.Decimal(14, 2)
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  transactions   Transaction[]
  transfersOut   Transaction[] @relation("TransferFromWallet")
  transfersIn    Transaction[] @relation("TransferToWallet")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@map("wallets")
}

model SourceAccount {
  id           String   @id @default(cuid())
  name         String   @unique
  owner        String
  isActive     Boolean  @default(true) @map("is_active")
  transactions Transaction[]
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("source_accounts")
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  sortOrder     Int           @default(0) @map("sort_order")
  isDefault     Boolean       @default(false) @map("is_default")
  isActive      Boolean       @default(true) @map("is_active")
  subCategories SubCategory[]
  transactions  Transaction[]
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@map("categories")
}

model Goal {
  id            String   @id @default(cuid())
  title         String   @unique
  targetAmount  Decimal  @map("target_amount") @db.Decimal(14, 2)
  currentAmount Decimal  @default(0) @map("current_amount") @db.Decimal(14, 2)
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@map("goals")
}

model SubCategory {
  id           String        @id @default(cuid())
  name         String
  categoryId   String        @map("category_id")
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sortOrder    Int           @default(0) @map("sort_order")
  isDefault    Boolean       @default(false) @map("is_default")
  isActive     Boolean       @default(true) @map("is_active")
  transactions Transaction[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@unique([categoryId, name])
  @@index([categoryId, sortOrder])
  @@map("sub_categories")
}

model Transaction {
  id                  String               @id @default(cuid())
  type                TransactionType
  transactionDate     DateTime             @map("transaction_date")
  amount              Decimal              @db.Decimal(14, 2)
  walletId            String?              @map("wallet_id")
  wallet              Wallet?              @relation(fields: [walletId], references: [id], onDelete: Restrict)
  fromWalletId        String?              @map("from_wallet_id")
  fromWallet          Wallet?              @relation("TransferFromWallet", fields: [fromWalletId], references: [id], onDelete: Restrict)
  toWalletId          String?              @map("to_wallet_id")
  toWallet            Wallet?              @relation("TransferToWallet", fields: [toWalletId], references: [id], onDelete: Restrict)
  sourceAccountId     String?              @map("source_account_id")
  sourceAccount       SourceAccount?       @relation(fields: [sourceAccountId], references: [id], onDelete: Restrict)
  categoryId          String?              @map("category_id")
  category            Category?            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subCategoryId       String?              @map("sub_category_id")
  subCategory         SubCategory?         @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)
  adjustmentDirection AdjustmentDirection? @map("adjustment_direction")
  description         String?
  createdById         String               @map("created_by")
  createdBy           User                 @relation("CreatedTransactions", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById         String?              @map("updated_by")
  updatedBy           User?                @relation("UpdatedTransactions", fields: [updatedById], references: [id], onDelete: Restrict)
  deletedById         String?              @map("deleted_by")
  deletedBy           User?                @relation("DeletedTransactions", fields: [deletedById], references: [id], onDelete: Restrict)
  deletedAt           DateTime?            @map("deleted_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@index([transactionDate])
  @@index([type])
  @@index([walletId])
  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("transactions")
}
